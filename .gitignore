# ──────────────────────────────────────────────
# THOTH .gitignore
# ──────────────────────────────────────────────

# ── Build & Runtime Artifacts ────────────────
build/
*.o
*.so
*.a
*.dylib
*.dll
*.exe
cmake-build-*/
_build/
CMakeCache.txt
CMakeFiles/

# ── Python ───────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class
*.egg-info/
.mypy_cache/
.pytest_cache/
*.eggs/
dist/

# ── Virtual Environments ────────────────────
.venv/
.venv-*/
venv/
env/

# ── Model Weights (too large for git) ───────
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.ot
*.ckpt

# ── Secrets & Credentials (NEVER upload) ────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.secret
*.token
credentials*
*_rsa
*_ed25519
*_ecdsa
id_dsa

# ── IDE / Editor ────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ──────────────────────────────────
*.tar
*.tar.gz
*.tar.zst

# ── Logs ────────────────────────────────────
*.log
logs/

# ── Node (if any tooling) ───────────────────
node_modules/

# ── ROCm / HIP Build Caches ────────────────
*.hsaco
*.hipfb
*.miopen
.cache/
*.kdb

# ── Core Dumps ──────────────────────────────
core
core.*
vgcore.*

# ── Temporary / Scratch ─────────────────────
*.tmp
*.temp
*.bak
*.orig
*.swp
scratch/
tmp/

# ── Archives (local build outputs) ──────────
*.zip
*.7z
*.xz
*.bz2
models
